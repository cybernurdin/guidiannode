{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo \"Skipping Node install; Flutter dependencies are installed by scripts/vercel_build.sh\"",
  "buildCommand": "bash scripts/vercel_build.sh",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://guidiannode-api-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
