PORT=3000
NODE_ENV=development

# Local frontend and API URLs.
APP_BASE_URL=http://localhost:5174
CLIENT_ORIGIN=http://localhost:5174
CORS_ORIGIN=http://localhost:5174
WEBHOOK_URL=https://your-development-tunnel.example/webhook

# Supabase is the current database provider. DATABASE_URL is reserved for
# deployment platforms that expose a direct PostgreSQL connection.
DATABASE_URL=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# GuardianNode signs stateless app sessions with JWT_SECRET. SESSION_SECRET is
# accepted as a compatibility fallback when JWT_SECRET is not set.
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters
SESSION_SECRET=

GOOGLE_MAPS_SERVER_API_KEY=your_google_server_api_key
JSON_BODY_LIMIT=1mb

DEBUG_AUTH_MODE=false
AUTO_VERIFY_DEBUG_OTP=false
OTP_EXPIRES_MINUTES=10

META_APP_ID=your_meta_app_id
META_BUSINESS_ID=your_meta_business_id
WHATSAPP_API_VERSION=v22.0
WHATSAPP_TARGET_NUMBER=237657262038
WHATSAPP_BUSINESS_NUMBER=237657262038
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
WHATSAPP_VERIFY_TOKEN=replace_with_a_random_webhook_verify_token

# Required for signed incoming webhook validation in production.
WHATSAPP_APP_SECRET=replace_with_your_meta_app_secret

# Optional for the inbound-only auth flow. Set this only if the backend later
# sends outbound WhatsApp Cloud API messages.
WHATSAPP_ACCESS_TOKEN=
