PORT=3000
NODE_ENV=production
WEBHOOK_URL=https://guidiannode-production.up.railway.app/webhook
APP_BASE_URL=https://your-public-app.example
DATABASE_URL=

# Public production origins that are allowed to call the API.
# Use HTTPS only. Separate multiple origins with commas.
CLIENT_ORIGIN=https://your-public-website.example
CORS_ORIGIN=https://your-public-website.example

# Supabase production project credentials.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Server-side Google Maps API key. Restrict this key by API and server IP where possible.
GOOGLE_MAPS_SERVER_API_KEY=your_google_server_api_key

# Use a strong random production secret. Do not reuse the development JWT secret.
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
SESSION_SECRET=

JSON_BODY_LIMIT=1mb

# Production registration verification by inbound WhatsApp message.
DEBUG_AUTH_MODE=false
AUTO_VERIFY_DEBUG_OTP=false
META_APP_ID=your_meta_app_id
META_BUSINESS_ID=your_meta_business_id
WHATSAPP_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
WHATSAPP_VERIFY_TOKEN=replace_with_a_random_production_verify_token
# Optional for this inbound-only flow. Required only if the backend later sends Cloud API messages.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=replace_with_meta_app_secret
WHATSAPP_TARGET_NUMBER=237657262038
WHATSAPP_BUSINESS_NUMBER=237657262038

OTP_EXPIRES_MINUTES=10
